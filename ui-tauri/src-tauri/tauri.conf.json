{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "言栖",
  "version": "0.8.1",
  "identifier": "com.xinyang.vernest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "言栖",
        "width": 430,
        "height": 720,
        "minWidth": 390,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:47632"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "externalBin": [
      "bin/vernest-backend"
    ],
    "publisher": "孙欣阳",
    "homepage": "https://github.com/Xinyang-S/STT-YanQi/tree/main",
    "copyright": "Copyright © 2026 孙欣阳. All rights reserved.",
    "license": "MIT",
    "licenseFile": "../../LICENSE",
    "shortDescription": "Vernest voice input",
    "longDescription": "言栖 Vernest 是一款 Windows 桌面语音输入工具，默认使用本地识别，并为后续可选增强能力预留架构。",
    "resources": {
      "../../models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/model.int8.onnx": "models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/model.int8.onnx",
      "../../models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/tokens.txt": "models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/tokens.txt",
      "../../models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/README.md": "models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/README.md",
      "../../models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/LICENSE": "models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17/LICENSE"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
